class Solution {
    public int getSecondLargest(int[] arr) {
        int max=-1;
        int second=-1;
        for(int i=0;i<arr.length;i++){
            if(max<arr[i]){
                second=max;
                 max=arr[i];
            }
            else if(second<arr[i] && max!=arr[i]){
                second=arr[i];
            }
        }
        return second;
    }
}
