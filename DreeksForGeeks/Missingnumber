class Solution {
    public int missingNumber(int[] arr) {
        Arrays.sort(arr);
        int n=arr.length;
        int i=0;
        while(i<n && arr[i]<=0) i++;
        if(i==n) return 1;
        if(arr[i]!=1) return 1;
        while(i<n-1){
            if(arr[i+1]==arr[i]){
                i++;
            }
            else if(arr[i+1]==arr[i]+1){
                i++;
            }
            else{
                break;
            }
        }
        return arr[i]+1;
    }
}
