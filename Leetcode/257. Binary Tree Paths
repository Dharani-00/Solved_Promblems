/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    private void path(TreeNode root,StringBuilder sb,List<String> li){
        if(root.left==null  && root.right==null){
            li.add(new String(sb));
            return;
        }
        int len=sb.length();
        if(root.left!=null){
            path(root.left,sb.append("->").append(root.left.val),li);
            sb.setLength(len);
        }
        if(root.right!=null){
            path(root.right,sb.append("->").append(root.right.val),li);
        sb.setLength(len);
        }
    }
    public List<String> binaryTreePaths(TreeNode root) {
       List<String> li =new LinkedList<>();
        path(root,new StringBuilder(""+root.val),li);
        return li;

    }
}
